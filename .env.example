# Copy this file to `.env` and fill in your Discord webhook URL(s).
# In Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL

# Normal activity (cat spotted anywhere + visit clips). Mute this channel if you like.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/yyyyyyyy

# Urgent unsafe-zone alerts (cat on the sofa). Route to a channel you keep unmuted.
# Optional — if omitted, urgent alerts fall back to DISCORD_WEBHOOK_URL above.
DISCORD_URGENT_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/zzzzzzzz
